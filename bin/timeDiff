#!/bin/sh

# figure out where the start time is coming from
startFile="$HOME/start_time"
if [ "$#" = 0 ]; then
    if [ -e "$startFile" ]; then
        startArg=$(cat "$startFile")
    else
        echo "$startFile not found. Please enter a start time as an argument."
        exit 1
    fi
else
    startArg="$1"
fi

# get epoch-based start and end times, in seconds
startTime=$(date -d "$startArg" +"%s")
endTime=$(date -d "${2:-$(date)}" +"%s")

# get interval, in truncated decimal hours
bc <<EOF
scale=1
time=($endTime - $startTime) / 3600
if(time<1 && time>0) print 0
time
EOF

exit 0
