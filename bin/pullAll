#!/bin/bash

cmd="pull"
recrsv=0
pdext=""

while getopts ":c:rs" opt; do
    case ${opt} in
        r ) recrsv=1
            ;;
        s ) pdext="&>/dev/null"
            ;;
        c ) cmd="$OPTARG"
            ;;
        \?) echo "Usage: pullAll [-rs] [-c <command>]"
            ;;
    esac
done

doPull() {
    eval "pushd $pdext $1"
    if [[ -z $(git status -s 2>&1) ]]; then
        eval "git ${cmd}"
    elif (($2)) && ! [ -d .git ]; then
        pullDir "$2"
    fi
    eval "popd $pdext"
}

pullDir() {
    for name in *; do
        [[ -d "$name" ]] && doPull "$name" "$1"
    done
}

pullDir "$recrsv"
