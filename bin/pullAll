#!/bin/bash

recrsv=0

while getopts r name; do
    case $name in
        r) recrsv=1;;
    esac
done

doPull() {
    pushd "$1"
    if [[ -z $(git status -s 2>&1) ]]; then
        git pull
    elif (($2)) && ! [ -d .git ]; then
        pullDir "$2"
    fi
    popd
}

pullDir() {
    for name in *; do
        [[ -d "$name" ]] && doPull "$name" "$1"
    done
}

pullDir "$recrsv"
